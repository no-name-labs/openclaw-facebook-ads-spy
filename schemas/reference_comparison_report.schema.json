{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReferenceComparisonReport",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "search_session_id": { "type": "string" },
    "keyword": { "type": "string" },
    "date_from": { "type": ["string", "null"] },
    "date_to": { "type": ["string", "null"] },
    "geo": { "type": "string", "const": "US" },
    "verdict": { "type": "string", "enum": ["pass", "partial", "fail"] },
    "advertiser_overlap": { "type": "number" },
    "landing_domain_overlap": { "type": "number" },
    "creative_similarity": { "type": "number" },
    "duplicate_handling_notes": { "type": "string" },
    "own_result_count": { "type": "integer" },
    "reference_result_count": { "type": "integer" },
    "own_advertisers": { "type": "array", "items": { "type": "string" } },
    "reference_advertisers": { "type": "array", "items": { "type": "string" } },
    "own_landing_domains": { "type": "array", "items": { "type": "string" } },
    "reference_landing_domains": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } },
    "raw_reference_payload": { "type": ["object", "null"] }
  },
  "required": [
    "search_session_id",
    "keyword",
    "date_from",
    "date_to",
    "geo",
    "verdict",
    "advertiser_overlap",
    "landing_domain_overlap",
    "creative_similarity",
    "duplicate_handling_notes",
    "own_result_count",
    "reference_result_count",
    "own_advertisers",
    "reference_advertisers",
    "own_landing_domains",
    "reference_landing_domains",
    "notes",
    "raw_reference_payload"
  ]
}
