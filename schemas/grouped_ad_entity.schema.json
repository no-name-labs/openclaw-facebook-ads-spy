{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GroupedAdEntity",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "group_key": { "type": "string" },
    "representative_ad_archive_id": { "type": "string" },
    "advertiser": { "type": "string" },
    "page_id": { "type": "string" },
    "page_profile_url": { "type": ["string", "null"] },
    "ad_library_links": { "type": "array", "items": { "type": "string" } },
    "raw_ad_ids": { "type": "array", "items": { "type": "string" } },
    "landing_page_urls": { "type": "array", "items": { "type": "string" } },
    "landing_domain": { "type": ["string", "null"] },
    "landing_domains": { "type": "array", "items": { "type": "string" } },
    "search_domain": { "type": ["string", "null"] },
    "search_domains": { "type": "array", "items": { "type": "string" } },
    "creative_text": { "type": ["string", "null"] },
    "creative_text_availability": {
      "type": "string",
      "enum": ["resolved", "placeholder_unresolved", "unavailable"]
    },
    "creative_titles": { "type": "array", "items": { "type": "string" } },
    "creative_titles_availability": {
      "type": "string",
      "enum": ["resolved", "placeholder_unresolved", "unavailable"]
    },
    "display_format": { "type": ["string", "null"] },
    "media_url": { "type": ["string", "null"] },
    "media_urls": { "type": "array", "items": { "type": "string" } },
    "media_kind": { "type": ["string", "null"], "enum": ["photo", "video", null] },
    "media_outcome": { "type": ["string", "null"] },
    "text_fallback_used": { "type": "boolean" },
    "native_media_sent": { "type": "boolean" },
    "active_start_date": { "type": ["string", "null"] },
    "active_end_date": { "type": ["string", "null"] },
    "days_active": { "type": ["integer", "null"] },
    "duplicate_count": { "type": "integer", "minimum": 1 },
    "creative_variants_count": { "type": "integer", "minimum": 1 },
    "grouped_notes": { "type": ["string", "null"] },
    "page_likes": { "type": ["integer", "null"] },
    "ig_followers": { "type": ["integer", "null"] },
    "representative": { "$ref": "./raw_ad_record.schema.json" },
    "duplicates_present": { "type": "boolean" },
    "raw_ads": {
      "type": "array",
      "items": { "$ref": "./raw_ad_record.schema.json" }
    }
  },
  "required": [
    "group_key",
    "representative_ad_archive_id",
    "advertiser",
    "page_id",
    "page_profile_url",
    "ad_library_links",
    "raw_ad_ids",
    "landing_page_urls",
    "landing_domain",
    "landing_domains",
    "search_domain",
    "search_domains",
    "creative_text",
    "creative_text_availability",
    "creative_titles",
    "creative_titles_availability",
    "display_format",
    "media_url",
    "media_urls",
    "media_kind",
    "media_outcome",
    "text_fallback_used",
    "native_media_sent",
    "active_start_date",
    "active_end_date",
    "days_active",
    "duplicate_count",
    "creative_variants_count",
    "grouped_notes",
    "page_likes",
    "ig_followers",
    "representative",
    "duplicates_present",
    "raw_ads"
  ]
}
